<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.Ps5CategoryMapper">

    <resultMap type="Ps5Category" id="Ps5CategoryResult">
        <id     property="categoryId"   column="category_id"   />
        <result property="categoryName" column="category_name" />
        <result property="icon"         column="icon"          />
        <result property="sort"         column="sort"          />
        <result property="status"       column="status"        />
        <result property="createBy"     column="create_by"     />
        <result property="createTime"   column="create_time"   />
        <result property="updateBy"     column="update_by"     />
        <result property="updateTime"   column="update_time"   />
        <result property="remark"       column="remark"        />
    </resultMap>

    <sql id="selectCategoryVo">
        select category_id, category_name, icon, sort, status, create_by, create_time, update_by, update_time, remark
        from ps5_category
    </sql>

    <select id="selectCategoryList" parameterType="Ps5Category" resultMap="Ps5CategoryResult">
        <include refid="selectCategoryVo"/>
        <where>
            <if test="categoryName != null and categoryName != ''">
                AND category_name like concat('%', #{categoryName}, '%')
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
        </where>
        ORDER BY sort ASC
    </select>

    <select id="selectCategoryById" parameterType="Long" resultMap="Ps5CategoryResult">
        <include refid="selectCategoryVo"/>
        WHERE category_id = #{categoryId}
    </select>

    <insert id="insertCategory" parameterType="Ps5Category" useGeneratedKeys="true" keyProperty="categoryId">
        INSERT INTO ps5_category (category_name, icon, sort, status, create_by, create_time, remark)
        VALUES (#{categoryName}, #{icon}, #{sort}, #{status}, #{createBy}, sysdate(), #{remark})
    </insert>

    <update id="updateCategory" parameterType="Ps5Category">
        UPDATE ps5_category
        <set>
            <if test="categoryName != null">category_name = #{categoryName},</if>
            <if test="icon != null">icon = #{icon},</if>
            <if test="sort != null">sort = #{sort},</if>
            <if test="status != null">status = #{status},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </set>
        WHERE category_id = #{categoryId}
    </update>

    <delete id="deleteCategoryByIds" parameterType="Long">
        DELETE FROM ps5_category WHERE category_id IN
        <foreach item="id" collection="array" open="(" separator="," close=")">#{id}</foreach>
    </delete>

</mapper>
