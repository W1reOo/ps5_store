<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.Ps5GameCommentMapper">

    <resultMap type="Ps5GameComment" id="Ps5GameCommentResult">
        <id     property="commentId"  column="comment_id"  />
        <result property="gameId"     column="game_id"     />
        <result property="userId"     column="user_id"     />
        <result property="userName"   column="user_name"   />
        <result property="userAvatar" column="user_avatar" />
        <result property="parentId"   column="parent_id"   />
        <result property="rootId"     column="root_id"     />
        <result property="replyToUserId"   column="reply_to_user_id"   />
        <result property="replyToUserName" column="reply_to_user_name" />
        <result property="content"    column="content"     />
        <result property="status"     column="status"      />
        <result property="createTime" column="create_time" />
    </resultMap>

    <sql id="selectCommentColsJoin">
        c.comment_id, c.game_id, c.user_id, c.user_name, c.parent_id, c.root_id,
        c.reply_to_user_id, c.reply_to_user_name, c.content, c.status, c.create_time,
        u.avatar AS user_avatar
    </sql>

    <sql id="fromCommentJoinUser">
        FROM ps5_game_comment c
        LEFT JOIN sys_user u ON c.user_id = u.user_id AND u.del_flag = '0'
    </sql>

    <select id="selectCommentById" parameterType="Long" resultMap="Ps5GameCommentResult">
        SELECT <include refid="selectCommentColsJoin"/>
        <include refid="fromCommentJoinUser"/>
        WHERE c.comment_id = #{commentId}
    </select>

    <select id="selectTopLevelByGameId" parameterType="Long" resultMap="Ps5GameCommentResult">
        SELECT <include refid="selectCommentColsJoin"/>
        <include refid="fromCommentJoinUser"/>
        WHERE c.game_id = #{gameId} AND c.status = '0' AND c.parent_id IS NULL
        ORDER BY c.create_time DESC
    </select>

    <select id="selectRepliesByRootIds" resultMap="Ps5GameCommentResult">
        SELECT <include refid="selectCommentColsJoin"/>
        <include refid="fromCommentJoinUser"/>
        WHERE c.game_id = #{gameId} AND c.status = '0'
          AND c.parent_id IS NOT NULL
          AND c.root_id IN
        <foreach collection="rootIds" item="rid" open="(" separator="," close=")">
            #{rid}
        </foreach>
        ORDER BY c.create_time ASC
    </select>

    <insert id="insertComment" parameterType="Ps5GameComment" useGeneratedKeys="true" keyProperty="commentId">
        INSERT INTO ps5_game_comment (
            game_id, user_id, user_name, parent_id, root_id,
            reply_to_user_id, reply_to_user_name, content, status, create_time
        ) VALUES (
            #{gameId}, #{userId}, #{userName}, #{parentId}, #{rootId},
            #{replyToUserId}, #{replyToUserName}, #{content}, '0', sysdate()
        )
    </insert>

    <update id="updateRootSelf" parameterType="Long">
        UPDATE ps5_game_comment
        SET root_id = comment_id
        WHERE comment_id = #{commentId} AND parent_id IS NULL
    </update>
</mapper>
